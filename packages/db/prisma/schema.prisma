// ============================================================
// Gamification — scratch cards, jackpots, mystery box, streaks
// ============================================================

enum GameType {
  scratch_card
  jackpot
  mystery_box
  spin_wheel
  streak
  daily_quest   // Deploy 118 — 3-step quest, all steps complete = bonus Goins
  streak_ladder // Deploy 118 — multi-rung climb (3/7/14/30 days) with claim
  treasure_hunt // Deploy 119 — pick 1 of N boxes, find the treasure
  goin_wager    // Deploy 119 — stake Goins, double-or-nothing with tiered odds
  product_drop  // Deploy 120 — win a real product; pay only ₹shipping
}

enum RewardType {
  goins            // adds to Customer.coinBalance
  discount_pct     // e.g., value = "15" → 15% off
  discount_flat    // e.g., value = "100" → ₹100 off
  free_shipping
  free_gift_wrap
  free_product     // value = Product.id
  miss             // no reward (but usually paired with consolation goins)
}

enum RewardStatus {
  pending   // won but not yet applied to a cart
  applied   // attached to a cart (not yet checked out)
  used      // redeemed against a completed order
  expired
}

// Admin-configurable reward pool per game type.
// rewardPool is a JSON array: [{ type: RewardType, value: string, weight: int,
//   minCart?: number, maxStock?: number, claimed?: number, label?: string }]
model GameConfig {
  id              String   @id @default(uuid()) @db.Uuid
  type            GameType @unique
  title           String
  description     String?
  rewardPool      Json     @map("reward_pool")
  dailyLimit      Int      @default(1)    @map("daily_limit")
  cooldownMinutes Int      @default(0)    @map("cooldown_minutes")
  costGoins       Int      @default(0)    @map("cost_goins")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt     @map("updated_at")

  @@map("game_configs")
}

model GamePlay {
  id           String    @id @default(uuid()) @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  gameType     GameType  @map("game_type")
  rewardType   RewardType @map("reward_type")
  rewardValue  String    @map("reward_value")
  rewardLabel  String?   @map("reward_label")
  costGoins    Int       @default(0) @map("cost_goins")
  rewardId     String?   @map("reward_id") @db.Uuid
  triggerRef   String?   @map("trigger_ref")  // orderId that triggered this play (if any)
  // Game-specific extra state — Deploy 118 uses { step: "1"|"2"|"3"|"bonus" }
  // for Daily Quest and { rung: number } for Streak Ladder. Deploy 119 uses
  // { stake, outcome, multiplier, payout, net } for Goin Wager and
  // { pickIndex, rewardLabel } for Treasure Hunt. The "Product Drop" game
  // (Deploy 120) stores { productId, won: bool, configId }.
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at")

  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([gameType, createdAt])
  @@map("game_plays")
}

// A single redeemable reward instance owned by a customer. Created when a
// reward other than `goins` / `miss` is won (coins go straight to balance).
// Redemption flow: pending → applied (attached to cart) → used (on checkout).
model RewardInstance {
  id            String       @id @default(uuid()) @db.Uuid
  customerId    String       @map("customer_id") @db.Uuid
  type          RewardType
  value         String       // discount pct/flat amount | product id | ""
  label         String       // human-readable e.g. "15% off" or "Free Gift Wrap"
  source        GameType     // which game produced it
  code          String?      @unique // generated coupon code, e.g. "SCR-A1B2"
  minCartInr    Int          @default(0) @map("min_cart_inr")
  status        RewardStatus @default(pending)
  appliedCartId String?      @map("applied_cart_id")
  usedOrderId   String?      @map("used_order_id") @db.Uuid
  expiresAt     DateTime?    @map("expires_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt    @map("updated_at")

  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, status])
  @@index([code])
  @@map("reward_instances")
}

// ============================================================
// Sticker Album (Panini-style collectible)
// ============================================================

model Sticker {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique                   // e.g. "ANI_01"
  name      String
  emoji     String
  theme     String                              // "animals" | "festivals" | "food" | "things" | "nature"
  rarity    String                              // "common" | "rare" | "legendary"
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  userStickers UserSticker[]

  @@index([theme, sortOrder])
  @@map("stickers")
}

model UserSticker {
  id                   String   @id @default(uuid()) @db.Uuid
  customerId           String   @map("customer_id") @db.Uuid
  stickerId            String   @map("sticker_id") @db.Uuid
  qty                  Int      @default(1)
  firstEarnedFromOrder String?  @map("first_earned_from_order")
  collectedAt          DateTime @default(now()) @map("collected_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sticker  Sticker  @relation(fields: [stickerId],  references: [id], onDelete: Cascade)

  @@unique([customerId, stickerId])
  @@index([customerId])
  @@map("user_stickers")
}

// Tracks which row (or the full album) a customer has claimed the prize for.
// Also used for volume claims in the new pack-based model — kind format is
// "row:<theme>" (legacy) or "volume:<volumeName>" (pack model) or "album".
model AlbumClaim {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  kind       String                              // "row:animals" | "volume:Festive Spirit" | "album"
  rewardId   String?  @map("reward_id") @db.Uuid
  claimedAt  DateTime @default(now()) @map("claimed_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, kind])
  @@map("album_claims")
}

// User-set gift reminders — one row per occasion-to-remember.
// Customer sets these up once ("Mom's birthday, July 12, yearly") and the
// daily cron job notifies + optionally auto-orders N days before.
//
// `eventDate` stores the occasion date. When `recurring=true`, only the
// month/day matter (year rolls forward). For Birthday-style recurring
// events, the cron computes the next occurrence from today.
//
// `autoOrder` requires `productId` + `savedAddressId` to be set. The daily
// job places a COD order using OrdersService. If any prerequisite is
// missing, we fall back to a notification-only reminder.
model GiftReminder {
  id                 String   @id @default(uuid()) @db.Uuid
  customerId         String   @map("customer_id") @db.Uuid
  occasion           String                                      // "birthday" | "anniversary" | "christmas" | "custom"
  recipientName      String?  @map("recipient_name")             // "Mom", "Priya"
  eventDate          DateTime @map("event_date")                 // occasion date (year-agnostic if recurring)
  recurring          Boolean  @default(true)                     // yearly repeat
  notifyDaysBefore   Int      @default(7) @map("notify_days_before")
  budgetMin          Int?     @map("budget_min")                 // INR
  budgetMax          Int?     @map("budget_max")
  preferredCategoryId String? @db.Uuid @map("preferred_category_id")
  productId          String?  @db.Uuid @map("product_id")         // pinned gift for auto-order
  autoOrder          Boolean  @default(false) @map("auto_order")
  savedAddressId     String?  @db.Uuid @map("saved_address_id")  // where to ship auto-orders
  note               String?                                      // free-text, e.g. "avoid lilies"
  active             Boolean  @default(true)
  lastNotifiedAt     DateTime? @map("last_notified_at")           // dedup daily cron
  lastAutoOrderedAt  DateTime? @map("last_auto_ordered_at")       // prevent repeat within same year
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, active])
  @@index([eventDate])
  @@map("gift_reminders")
}

// One row per installed-app-instance. A customer can have multiple devices
// (phone + tablet + web). We upsert by (customerId, token) on register and
// delete on logout or on FCM "token expired" errors. Notifications service
// iterates the list when sending a per-customer push.
model DeviceToken {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  token      String   @unique                       // FCM token (opaque string)
  platform   String                                  // "android" | "ios" | "web"
  appVersion String?  @map("app_version")
  deviceName String?  @map("device_name")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("device_tokens")
}

// Per-customer sticker-economy profile — tracks unopened pack inventory and
// total coins earned from duplicate conversions. Introduced for the pack-
// based album UI; legacy row-based flows don't touch it.
model UserStickerProfile {
  id          String   @id @default(uuid()) @db.Uuid
  customerId  String   @unique @map("customer_id") @db.Uuid
  packs       Int      @default(3)                  // new users get 3 packs
  coinsEarned Int      @default(0) @map("coins_earned")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("user_sticker_profiles")
}

// ============================================================
// Duet Jackpot — sender+recipient both get a scratch card
// ============================================================

model DuetInvite {
  id         String    @id @default(uuid()) @db.Uuid
  senderId   String    @map("sender_id") @db.Uuid
  senderName String?   @map("sender_name")
  orderId   String    @map("order_id") @db.Uuid
  token      String    @unique
  claimedAt  DateTime? @map("claimed_at")
  claimedBy  String?   @map("claimed_by") @db.Uuid
  rewardId   String?   @map("reward_id") @db.Uuid
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  sender  Customer  @relation("SenderDuets",  fields: [senderId],  references: [id], onDelete: Cascade)
  claimer Customer? @relation("ClaimedDuets", fields: [claimedBy], references: [id])

  @@index([senderId])
  @@map("duet_invites")
