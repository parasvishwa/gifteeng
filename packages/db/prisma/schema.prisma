// Gifteeng unified schema — merges B2B and B2C into a single Postgres DB.
// Two auth silos (customers, company_users) share one commerce backbone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum Channel {
  b2c
  b2b
}

enum UserRole {
  super_admin
  sales_admin
  hr_admin
  production
  employee
}

enum CompanyStatus {
  active
  suspended
  pending
}

enum OrderStatus {
  new_order
  confirmed
  in_production
  ready_to_ship
  shipped
  delivered
  cancelled
  returned
}

enum PayoutStatus {
  pending     // items collected, not yet past eligibility window
  eligible    // past return + 10-day window — ready for bank transfer
  processing  // admin initiated the bank transfer
  paid        // confirmed paid to seller
  cancelled
}

enum AssignmentStatus {
  pending     // assigned to seller, awaiting acceptance
  accepted    // seller accepted — will fulfil
  processing  // seller is preparing / in production
  dispatched  // seller dispatched with courier
  delivered   // confirmed delivered to buyer
  returned    // buyer returned item
  floating    // seller missed deadline — being re-routed
  cancelled   // all sellers exhausted — permanently stuck
}

enum OrderPriority {
  low
  normal
  high
  urgent
}

enum PaymentMethod {
  razorpay
  wallet
  cod
  invoice
}

enum PaymentStatus {
  pending
  authorized
  captured
  failed
  refunded
}

enum CampaignType {
  festival
  reward
  onboarding
  milestone
  custom
}

enum CampaignStatus {
  draft
  active
  completed
  cancelled
}

enum AllocationStatus {
  pending
  partial
  redeemed
  expired
}

enum WalletOwnerType {
  company
  employee
}

enum WalletTxnType {
  topup
  debit
  refund
  lock
  unlock
}

enum FileOwnerType {
  product
  customer
  company_user
  order
  review
  design_template
  thank_you_card
  system
}

enum CoinTxnType {
  spin_wheel
  referral
  order_bonus
  redemption
  admin_grant
  expiry
  scratch_card
  jackpot
  mystery_box
  streak_reward
  daily_quest    // Deploy 118
  treasure_hunt  // Deploy 119
  goin_wager     // Deploy 119 (both stake deductions and winnings)
}

// ============================================================
// Identity & tenancy
// ============================================================

model Company {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  slug           String        @unique
  logoUrl        String?
  brandColor     String?
  status         CompanyStatus @default(active)
  billingEmail   String?
  billingAddress Json?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  companyUsers   CompanyUser[]
  orders         Order[]
  ownedProducts  Product[]     @relation("OwnerCompany")
  priceSlabs     PriceSlab[]

  @@map("companies")
}

model CompanyUser {
  id            String    @id @default(uuid()) @db.Uuid
  companyId     String    @db.Uuid
  email         String
  phone         String?
  fullName      String?
  passwordHash  String?
  role          UserRole
  /// Granular permission strings (e.g. "products.create", "categories.delete").
  /// Used in addition to `role` so a single user can be granted permissions
  /// from multiple feature areas without inventing a new role. The
  /// `super_admin` role bypasses this list (full access). See
  /// apps/api/src/modules/auth-b2b/permissions.ts for the canonical catalog.
  permissions   String[]  @default([])
  invitedBy     String?   @db.Uuid
  invitedAt     DateTime?
  activatedAt   DateTime?
  lastLoginAt   DateTime?
  isActive      Boolean   @default(true)
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// Single-use invite token — hashed at rest (sha256) so a DB leak doesn't
  /// expose live invite links. Set on `/b2b/team/invite`, consumed on
  /// `/auth/b2b/accept-invite` (which sets passwordHash). Null once accepted
  /// or expired. Replaces the legacy "set password by email" flow which was
  /// vulnerable to account-takeover by anyone who knew the email.
  inviteTokenHash      String?
  inviteTokenExpiresAt DateTime?

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ordersPlaced  Order[]   @relation("OrderedByCompanyUser")

  @@unique([companyId, email])
  @@index([companyId, role])
  @@index([inviteTokenHash])
  @@map("company_users")
}

model Customer {
  id            String    @id @default(uuid()) @db.Uuid
  email         String?   @unique
  phone         String?   @unique
  fullName      String?
  passwordHash  String?
  googleId      String?   @unique @map("google_id")
  appleId       String?   @unique @map("apple_id")
  avatarUrl     String?   @map("avatar_url")
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  isAdmin       Boolean   @default(false)
  coinBalance   Int       @default(0) @map("coin_balance")
  lastSpinAt    DateTime? @map("last_spin_at")
  // Fraud watch (Deploy 117) — when frozen, the customer can still log in and
  // browse but every Goin earn / spend / spin method short-circuits. Set via
  // the super-admin audit log page. `frozenReason` records why.
  isFrozen      Boolean   @default(false) @map("is_frozen")
  frozenAt      DateTime? @map("frozen_at")
  frozenReason  String?   @map("frozen_reason")
  // Recommendations: cached LLM-derived shopper profile. Shape:
  // { summary: string, tags: string[], categories: string[], version: 1 }
  // Refreshed on order placement and on login if older than 7 days.
  aiProfile           Json?     @map("ai_profile")
  aiProfileComputedAt DateTime? @map("ai_profile_computed_at")
  metadata      Json?
  // DPDP — set when the customer requests deletion (default now + 30 days).
  // Daily cron anonymizes PII for any row past this timestamp; order rows
  // are preserved (tax/accounting law requires ~7 years of retention).
  // `dpdpAnonymizedAt` is stamped after processing to make the cron idempotent.
  dataDeletionScheduledFor DateTime? @map("data_deletion_scheduled_for")
  dpdpAnonymizedAt         DateTime? @map("dpdp_anonymized_at")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  cart          Cart?
  wishlists     Wishlist[]
  reviews       Review[]
  savedAddresses SavedAddress[]
  customerPhotos CustomerPhoto[]
  coinTransactions CoinTransaction[]
  gamePlays     GamePlay[]
  rewardInstances RewardInstance[]
  loginStreak   LoginStreak?
  bidEntries    BidEntry[]
  flashWinners  FlashJackpotWinner[]
  userStickers  UserSticker[]
  stickerProfile UserStickerProfile?
  albumClaims   AlbumClaim[]
  deviceTokens  DeviceToken[]
  giftReminders GiftReminder[]
  duetsSent     DuetInvite[]        @relation("SenderDuets")
  duetsClaimed  DuetInvite[]        @relation("ClaimedDuets")
  returnRequests ReturnRequest[]
  consents      ConsentRecord[]
  dataExports   DataExportRequest[]
  sellerFollows SellerFollower[]

  @@index([dataDeletionScheduledFor])
  @@map("customers")
}

model PhoneOtp {
  id         String   @id @default(uuid()) @db.Uuid
  phone      String
  codeHash   String
  purpose    String // 'b2c_login' | 'b2c_profile' | etc.
  attempts   Int      @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([phone, purpose])
  @@map("phone_otps")
}

// ============================================================
// Catalog
// ============================================================

model Product {
  id               String   @id @default(uuid()) @db.Uuid
  slug             String   @unique
  title            String
  description      String?
  category         String?
  brandName        String?  // marketplace brand label (seller's brand or house brand)
  basePrice        Decimal  @db.Decimal(12, 2)
  currency         String   @default("INR")
  sku              String?
  inventory        Int      @default(0)
  isCustomizable   Boolean  @default(false)
  mockupTemplates  Json?    // canvas templates
  images           Json?    // array of {url, alt}
  b2cEnabled       Boolean  @default(true)
  b2bEnabled       Boolean  @default(false)
  ownerCompanyId   String?  @db.Uuid // null = global
  metadata         Json?
  mrp          Decimal?  @db.Decimal(12, 2)  // market retail price; null = no discount advertised
  discountPct  Int?      @map("discount_pct") // ((mrp-basePrice)/mrp)*100, stored for fast filtering
  // Self-relation: ops curates 2–3 FBT products per product in admin
  frequentlyBoughtWith Product[] @relation("ProductFBT")
  frequentlyBoughtBy   Product[] @relation("ProductFBT")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ownerCompany     Company? @relation("OwnerCompany", fields: [ownerCompanyId], references: [id])
  variantOptions   ProductVariantOption[]
  priceSlabs       PriceSlab[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  wishlistItems    WishlistItem[]
  reviews          Review[]
  externalReviews  ExternalReview[]
  testimonials     Testimonial[]
  collectionLinks  ProductCollection[]
  dropConfigs      ProductDropConfig[] // Deploy 120 — product-drop campaigns
  sellerOffers     SellerProduct[]     // marketplace — sellers offering this product

  @@index([category, b2cEnabled])
  @@index([ownerCompanyId])
  @@index([discountPct, b2cEnabled])
  @@map("products")
}

model ProductVariantOption {
  id                 String  @id @default(uuid()) @db.Uuid
  productId          String  @db.Uuid
  name               String  // 'color', 'size', 'material'
  value              String
  priceDelta         Decimal @default(0) @db.Decimal(12, 2)
  sku                String?
  inventory          Int     @default(0)
  image              String?
  images             Json?
  customizationMode  String? // null=inherit | "full" | "simple" | "template" | "none"

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, name])
  @@map("product_variant_options")
}

model PriceSlab {
  id         String  @id @default(uuid()) @db.Uuid
  productId  String  @db.Uuid
  companyId  String? @db.Uuid // null = global tier
  minQty     Int
  maxQty     Int?
  unitPrice  Decimal @db.Decimal(12, 2)

  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  company    Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([productId, companyId])
  @@map("price_slabs")
}

model Collection {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  title       String
  description String?
  heroImage   String?
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  products    ProductCollection[]

  @@map("collections")
}

model ProductCollection {
  productId    String @db.Uuid
  collectionId String @db.Uuid
  sortOrder    Int    @default(0)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@map("product_collections")
}

// Catalog / CatalogItem / CatalogEnquiry models removed — the corporate
// B2B catalog offering was discontinued.

// ============================================================
// Commerce (orders, cart, etc.)
// ============================================================

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  orderNumber     String        @unique
  channel         Channel
  status          OrderStatus   @default(new_order)
  priority        OrderPriority @default(normal)

  customerId      String?       @db.Uuid
  companyId       String?       @db.Uuid
  companyUserId   String?       @db.Uuid

  subtotal        Decimal       @db.Decimal(12, 2)
  discountTotal   Decimal       @default(0) @db.Decimal(12, 2)
  shippingTotal   Decimal       @default(0) @db.Decimal(12, 2)
  taxTotal        Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal       @db.Decimal(12, 2)
  currency        String        @default("INR")

  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(pending)
  razorpayOrderId String?
  razorpayPaymentId String?

  shippingAddress Json?
  billingAddress  Json?
  discountCode    String?
  notes           String?
  metadata        Json?

  placedAt        DateTime      @default(now())
  confirmedAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  updatedAt       DateTime      @updatedAt

  customer        Customer?     @relation(fields: [customerId], references: [id])
  company         Company?      @relation(fields: [companyId], references: [id])
  companyUser     CompanyUser?  @relation("OrderedByCompanyUser", fields: [companyUserId], references: [id])
  items           OrderItem[]
  shipments       Shipment[]
  returnRequests  ReturnRequest[]

  @@index([channel, status])
  @@index([customerId])
  @@index([companyId])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @db.Uuid
  productId       String   @db.Uuid
  sellerProductId String?  @db.Uuid // marketplace — the seller offer this line was bought from
  qty             Int
  unitPrice       Decimal  @db.Decimal(12, 2)
  totalPrice      Decimal  @db.Decimal(12, 2)
  variantOptions  Json?    // snapshot of chosen variants
  customization   Json?    // fabric.js canvas JSON + assets
  snapshot        Json?    // product snapshot at time of order

  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id])
  sellerProduct   SellerProduct? @relation(fields: [sellerProductId], references: [id])
  returnRequests  ReturnRequest[]
  assignments     OrderItemAssignment[]

  @@index([orderId])
  @@index([sellerProductId])
  @@map("order_items")
}

model Shipment {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @db.Uuid
  provider        String   @default("shiprocket")
  awb             String?
  courier         String?
  trackingUrl     String?
  status          String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  providerPayload Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("shipments")
}

model Cart {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String?  @unique @db.Uuid
  sessionKey String?  @unique
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]

  @@map("carts")
}

model CartItem {
  id              String   @id @default(uuid()) @db.Uuid
  cartId          String   @db.Uuid
  productId       String   @db.Uuid
  sellerProductId String?  @db.Uuid // marketplace — chosen seller offer
  qty             Int
  variantOptions  Json?
  customization   Json?
  addedAt         DateTime @default(now())

  cart            Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id])
  sellerProduct   SellerProduct? @relation(fields: [sellerProductId], references: [id])

  @@index([cartId])
  @@map("cart_items")
}

model SavedAddress {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  label      String?
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String   @default("IN")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("saved_addresses")
}

model Wishlist {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  name       String   @default("Default")
  createdAt  DateTime @default(now())

  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      WishlistItem[]

  @@index([customerId])
  @@map("wishlists")
}

model WishlistItem {
  wishlistId String @db.Uuid
  productId  String @db.Uuid
  addedAt    DateTime @default(now())

  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([wishlistId, productId])
  @@map("wishlist_items")
}

model Discount {
  id           String    @id @default(uuid()) @db.Uuid
  code         String    @unique
  description  String?
  percent      Decimal?  @db.Decimal(5, 2)
  amount       Decimal?  @db.Decimal(12, 2)
  minOrderTotal Decimal? @db.Decimal(12, 2)
  usageLimit   Int?
  usedCount    Int       @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@map("discounts")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @db.Uuid
  customerId String?  @db.Uuid
  rating     Int
  title      String?
  body       String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id])
  photos     CustomerPhoto[]

  @@index([productId])
  @@map("reviews")
}

model CustomerPhoto {
  id         String   @id @default(uuid()) @db.Uuid
  reviewId   String?  @db.Uuid
  customerId String?  @db.Uuid
  url        String
  caption    String?
  createdAt  DateTime @default(now())

  review     Review?   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id])

  @@map("customer_photos")
}

// B2B wallet & campaign models (Wallet, WalletTransaction, Campaign,
// CampaignAllocation) removed — the corporate offering was discontinued.

// ============================================================
// Platform / misc
// ============================================================

model DesignTemplate {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  canvasJson Json     @default("{}")
  previewUrl String?
  category   String?
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("design_templates")
}

model ThankYouCard {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  size            String   @default("4x6")
  templateLabel   String?
  templateImage   String?
  backgroundImage String?
  foregroundImage String?
  price           Int      @default(5)
  textAreaX       Float    @default(10)
  textAreaY       Float    @default(60)
  textAreaWidth   Float    @default(80)
  textAreaHeight  Float    @default(30)
  maxFontSize     Int      @default(18)
  minFontSize     Int      @default(8)
  textColor       String   @default("#1A1A2E")
  textAlign       String   @default("center")
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  canvasJson      Json     @default("[]")
  previewUrl      String?
  createdAt       DateTime @default(now())

  @@map("thank_you_cards")
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// Historically named `page_views` — now a general analytics-event log.
// When `event` is null, the row represents an implicit `page_view` event
// for `path` (backward-compat with all existing rows).
// When `event` is set (e.g. "checkout_start", "pack_open"), `props` carries
// the event-specific payload (cartValue, rarity, productId, …).
model PageView {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id")
  path       String   @map("page_path")
  event      String?                                 // null → page_view; else named event
  props      Json?                                   // event-specific payload
  platform   String?                                 // "web" | "android" | "ios"
  appVersion String?  @map("app_version")
  referrer   String?
  userAgent  String?  @map("user_agent")
  deviceType String?  @map("device_type")
  browser    String?
  os         String?
  country    String?
  region     String?
  city       String?
  customerId String?  @db.Uuid @map("customer_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([path, createdAt])
  @@index([event, createdAt])
  @@index([customerId, createdAt])
  @@index([sessionId])
  @@index([createdAt])
  @@map("page_views")
}

// Pre-aggregated daily rollup of analytics events. Populated by a nightly
// cron (POST /admin/analytics/rollup-daily) which reads the previous day from
// `page_views` and upserts grouped rows here. The Analytics dashboard reads
// historical date-range stats from this table instead of scanning the raw
// events log — keeps queries fast even at 100M+ raw events.
//
// Once populated, raw page_views older than the retention window (90d) can be
// pruned via /admin/analytics/prune-old without losing historical reporting.
model PageViewDailySummary {
  id              String   @id @default(uuid()) @db.Uuid
  date            DateTime @db.Date                          // YYYY-MM-DD (UTC day)
  event           String                                     // 'page_view' for null events
  platform        String                                     // 'web', 'android', 'ios', 'unknown'
  count           Int                                        // total events that day
  uniqueSessions  Int      @default(0) @map("unique_sessions")
  uniqueCustomers Int      @default(0) @map("unique_customers")
  createdAt       DateTime @default(now())                   @map("created_at")
  updatedAt       DateTime @updatedAt                        @map("updated_at")

  @@unique([date, event, platform])
  @@index([date])
  @@index([event, date])
  @@map("page_view_daily_summary")
}

// ─────────────────────────────────────────────────────────────────────────────
// Cart abandonment recovery — admin-configurable notification campaigns sent
// to customers whose cart sits idle. Each rule defines a delay, conditions,
// notification template, and a per-customer cooldown to prevent spam.
// ─────────────────────────────────────────────────────────────────────────────

model CartRecoveryRule {
  id             String   @id @default(uuid()) @db.Uuid
  name           String                                                  // "Gentle nudge after 1h"
  triggerMinutes Int                                                     // fire when cart idle ≥ this many minutes
  minCartValue   Int?                                                    // paise — only fire if cartValue ≥ this
  maxCartValue   Int?                                                    // paise — only fire if cartValue ≤ this
  loggedInOnly   Boolean  @default(true)                                 // require linked customerId (push needs FCM token)
  title          String                                                  // supports {firstName}, {firstItem}, {itemCount}, {cartValue}
  body           String
  ctaText        String   @default("View cart")
  ctaUrl         String   @default("/cart")                              // deep link
  cooldownHours  Int      @default(48)                                   // don't re-send same rule to same user within
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  sentCount      Int      @default(0)                                    // denormalised counter for admin UI
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sends          CartRecoverySent[]

  @@index([isActive, sortOrder])
  @@map("cart_recovery_rules")
}

model CartRecoverySent {
  id          String   @id @default(uuid()) @db.Uuid
  ruleId      String   @db.Uuid
  customerId  String   @db.Uuid
  cartValue   Int                                                        // paise snapshot at send time
  itemCount   Int
  channel     String   @default("push")                                  // push | email | sms (future)
  sentAt      DateTime @default(now())

  rule        CartRecoveryRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([customerId, sentAt])
  @@index([ruleId, sentAt])
  @@map("cart_recovery_sent")
}

model FileAsset {
  id         String        @id @default(uuid()) @db.Uuid
  ownerType  FileOwnerType
  ownerId    String?       @db.Uuid
  path       String        // relative path under UPLOAD_DIR
  mimeType   String?
  sizeBytes  Int?
  checksum   String?
  createdAt  DateTime      @default(now())

  @@index([ownerType, ownerId])
  @@map("files")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  channel    String   // 'email' | 'sms' | 'inapp'
  recipient  String
  subject    String?
  body       String
  status     String   @default("queued")
  sentAt     DateTime?
  error      String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([status, createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorType  String   // 'customer' | 'company_user' | 'system'
  actorId    String?  @db.Uuid
  action     String
  entityType String?
  entityId   String?
  payload    Json?
