// ============================================================
// Secret Bid — lowest-unique-bid wins a premium item
// ============================================================

enum BidStatus {
  open
  closed
  resolved
}

model SecretBidItem {
  id              String      @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  imageUrl        String?     @map("image_url")
  productId       String?     @map("product_id") @db.Uuid     // optional link to real product
  prizeLabel      String      @map("prize_label")              // e.g., "Premium Gift Hamper worth ₹5,000"
  minBidGoins     Int         @default(10)  @map("min_bid_goins")
  maxBidGoins     Int         @default(500) @map("max_bid_goins")
  costPerEntry    Int         @default(100) @map("cost_per_entry") // goins to place one bid set
  opensAt         DateTime    @map("opens_at")
  closesAt        DateTime    @map("closes_at")
  status          BidStatus   @default(open)
  winnerEntryId   String?     @map("winner_entry_id") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt     @map("updated_at")

  entries         BidEntry[]

  @@index([status, closesAt])
  @@map("secret_bid_items")
}

model BidEntry {
  id          String        @id @default(uuid()) @db.Uuid
  bidItemId   String        @map("bid_item_id") @db.Uuid
  customerId  String        @map("customer_id") @db.Uuid
  bidAmount   Int           @map("bid_amount")      // the secret number
  costGoins   Int           @map("cost_goins")      // goins spent for this bid
  createdAt   DateTime      @default(now()) @map("created_at")

  bidItem     SecretBidItem @relation(fields: [bidItemId], references: [id], onDelete: Cascade)
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([bidItemId, bidAmount])
  @@index([customerId, createdAt])
  @@map("bid_entries")
}

// ============================================================
// Flash Jackpot — hourly random winner
// ============================================================

model FlashJackpotWinner {
  id           String    @id @default(uuid()) @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  rewardType   RewardType @map("reward_type")
  rewardValue  String    @map("reward_value")
  rewardLabel  String    @map("reward_label")
  rewardId     String?   @map("reward_id") @db.Uuid
  hourBucket   String    @unique @map("hour_bucket") // e.g., "2026-04-21-14" — one winner per hour
  createdAt    DateTime  @default(now()) @map("created_at")

  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("flash_jackpot_winners")
}

// Login streak tracker — one row per customer.
// currentStreak resets on miss (>1 day gap); longestStreak remembered.
model LoginStreak {
  id              String    @id @default(uuid()) @db.Uuid
  customerId      String    @unique @map("customer_id") @db.Uuid
  currentStreak   Int       @default(0) @map("current_streak")
  longestStreak   Int       @default(0) @map("longest_streak")
  lastCheckInAt   DateTime? @map("last_check_in_at")
  milestonesHit   Json      @default("[]") @map("milestones_hit") // array of day numbers claimed
  updatedAt       DateTime  @updatedAt @map("updated_at")

  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("login_streaks")
}

// ─────────────────────────────────────────────────────────────────────────────
// ExternalReview — aggregated review from third-party marketplaces (Amazon,
// Flipkart, Myntra, Google, Meesho, etc.) plus a manual-entry fallback for
// any source we can't fetch automatically.
//
// The dedicated /reviews page UNIONs these with native `Review` rows (where
// source is implicitly "gifteeng"). All reviews are visible only when
// rating >= MIN_VISIBLE_RATING (4 by default — enforced server-side).
// ─────────────────────────────────────────────────────────────────────────────
model ExternalReview {
  id           String   @id @default(uuid()) @db.Uuid
  source       String                                   // "amazon" | "flipkart" | "myntra" | "google" | "meesho" | "ajio" | "manual"
  sourceLogo   String?                                  // optional override URL — defaults to a built-in logo for known sources
  sourceUrl    String?                                  // direct link to original review on the source site
  rating       Int                                      // 1..5
  title        String?
  body         String
  author       String?                                  // reviewer's display name as shown on the source
  authorAvatar String?                                  // optional reviewer avatar URL
  reviewDate   DateTime?                                // when the review was originally posted on the source
  // Reviewer-attached media. photoUrls is an array of URLs (no upload needed —
  // external reviews link directly to the source CDN). videoUrl is a single
  // optional video URL. Both populated by the Chrome extension during scrape.
  photoUrls    Json?                                    // string[] — review images from the source
  videoUrl     String?                                  // optional video URL
  productId    String?  @db.Uuid                        // optional — tag review to a Gifteeng product
  isApproved   Boolean  @default(false)                 // admin moderation gate
  sortOrder    Int      @default(0)                     // manual order for the curated reviews page
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([isApproved, rating, sortOrder])
  @@index([source, isApproved])
  @@index([productId])
  @@map("external_reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// MilestoneRewardConfig — every-Nth-customer Goins drop.
//
// Two independent counters: signup-via-web (`webCounter`) and signup-via-app
// (`appCounter`). When a counter hits a multiple of `webEvery`/`appEvery`,
// that customer gets `webGoins`/`appGoins` credited + a celebratory push.
// On their next app/web open, a confetti popup celebrates the win.
// ─────────────────────────────────────────────────────────────────────────────
model MilestoneRewardConfig {
  id           String   @id @default("default")
  // Web-signup milestone
  webEnabled   Boolean  @default(true)
  webEvery     Int      @default(100)
  webGoins     Int      @default(1000)
  webTitle     String   @default("🎉 You're our {position}th visitor!")
  webBody      String   @default("As our {position}th website visitor, we've credited {amount} Goins to your wallet — happy gifting, {firstName}!")
  webCounter   Int      @default(0)                        // monotonic — incremented per web signup
  // App-signup milestone
  appEnabled   Boolean  @default(true)
  appEvery     Int      @default(100)
  appGoins     Int      @default(1000)
  appTitle     String   @default("🎉 You're our {position}th app user!")
  appBody      String   @default("As our {position}th app downloader, we've credited {amount} Goins to your wallet — enjoy, {firstName}!")
  appCounter   Int      @default(0)                        // monotonic — incremented per app signup
  ctaUrl       String   @default("/goins")
  updatedAt    DateTime @updatedAt

  @@map("milestone_reward_config")
}

model MilestoneRewardSent {
  id          String   @id @default(uuid()) @db.Uuid
  customerId  String   @db.Uuid
  kind        String                                       // "web" | "app"
  position    Int                                          // counter snapshot at award time
  amount      Int
  pushSent    Boolean  @default(false)
  sentAt      DateTime @default(now())

  @@index([customerId, sentAt])
  @@index([sentAt])
  @@index([kind, sentAt])
  @@map("milestone_reward_sent")
}

// ─────────────────────────────────────────────────────────────────────────────
// Inactivity Goin Rewards — re-engagement system that auto-credits random
// Goins to dormant customers and pushes "We missed you, here's X Goins!"
//
// Single-row config (id = "default") drives the cron at /admin/inactivity-rewards/run.
// Each award lands in `inactivity_reward_sent` so the cooldown filter works
// + the admin can audit who was rewarded.
// ─────────────────────────────────────────────────────────────────────────────
model InactivityRewardConfig {
  id                  String   @id @default("default")
  enabled             Boolean  @default(false)                  // master kill-switch
  minGoins            Int      @default(50)                     // floor of random reward
  maxGoins            Int      @default(500)                    // ceiling
  minInactiveDays     Int      @default(7)                      // last login must be ≥ this many days ago
  cooldownDays        Int      @default(14)                     // don't re-reward same user within
  maxLifetimePerUser  Int      @default(6)                      // hard cap so we don't spam serial inactives forever
  dailyDropRate       Int      @default(20)                     // % chance per eligible user per day (1..100). Adds randomness.
  pushTitleTemplate   String   @default("🎁 We missed you, {firstName}!")
  pushBodyTemplate    String   @default("We've added {amount} Goins to your wallet. Find a gift to brighten someone's day.")
  ctaUrl              String   @default("/goins")
  updatedAt           DateTime @updatedAt

  @@map("inactivity_reward_config")
}

model InactivityRewardSent {
  id          String   @id @default(uuid()) @db.Uuid
  customerId  String   @db.Uuid
  amount      Int                                                // Goins credited
  inactiveDays Int                                               // snapshot — how many days dormant when rewarded
  pushSent    Boolean  @default(false)
  sentAt      DateTime @default(now())

  @@index([customerId, sentAt])
  @@index([sentAt])
  @@map("inactivity_reward_sent")
}

// ─────────────────────────────────────────────────────────────────────────────
// HeroBanner — image-only hero slides, identical on web + Flutter.
//
// Design philosophy:
//   • One image is the entire banner — no app-rendered title/subtitle/CTA.
//   • Recommended source: 1500 × 500 (3:1), max 300 KB.
//   • placement="home" today; future placements (shop_top, cart_top, etc.)
//     drop in without a new model.
// ─────────────────────────────────────────────────────────────────────────────
model HeroBanner {
  id            String    @id @default(uuid()) @db.Uuid
  imageUrl      String                                       // desktop/web image (3:1, 1500×500 recommended)
  mobileImageUrl String?                                     @map("mobile_image_url") // phone/Flutter image (9:20, 750×1334 recommended) — falls back to imageUrl if null
  linkUrl       String    @default("/shop")                  // tap target — internal route or absolute URL
  placement     String    @default("home")                   // "home" | "shop_top" | "cart_top" …
  altText       String?                                      // a11y description
  startsAt      DateTime?                                    // optional time-window start
  endsAt        DateTime?                                    // optional time-window end
  sortOrder     Int       @default(0)                        // manual drag-to-reorder weight
  isActive      Boolean   @default(true)
  // Per-banner text overlay (left half of the hero composition). When all
  // of these are null the slide falls back to legacy image-only rendering
  // — i.e. the image fills the whole slide and the text column collapses.
  tagline       String?                                      @map("tagline")
  heading       String?                                      @map("heading")
  headingAccent String?                                      @map("heading_accent")
  subtitle      String?                                      @map("subtitle")
  button1Text   String?                                      @map("button1_text")
  button1Link   String?                                      @map("button1_link")
  button2Text   String?                                      @map("button2_text")
  button2Link   String?                                      @map("button2_link")
  // Per-banner color overrides — all nullable, fall back to brand defaults.
  textBgColor   String?                                      @map("text_bg_color")
  textColor     String?                                      @map("text_color")
  accentColor   String?                                      @map("accent_color")
  buttonColor   String?                                      @map("button_color")
  createdAt     DateTime  @default(now())                    @map("created_at")
  updatedAt     DateTime  @updatedAt                         @map("updated_at")

  @@index([placement, isActive, sortOrder])
  @@map("hero_banners")
}

// Home-screen announcements / event banners — admin-editable carousel.
// Used by the mobile event-reminder banner ("Valentine's Day in 6 days")
// and the web home hero strip. Supports time-windowed visibility
// (startsAt / endsAt) and multi-placement routing.
model Announcement {
  id          String    @id @default(uuid()) @db.Uuid
  title       String                            // "Valentine's Day"
  subtitle    String?                           // "Gifts for your loved one"
  emoji       String?                           // "💝"
  // Slug for shop-screen ?occasion=<slug> filtering — e.g. "mothers-day".
  // The mobile banner uses this to build /shop?occasion=<slug> when no
  // explicit `link` override is provided. Optional so legacy rows stay valid.
  slug        String?                           // "mothers-day"
  placement   String    @default("home")        // "home" | "shop" | "checkout" | "all"
  link        String    @default("/shop")       // deep-link route on tap
  eventDate   DateTime? @map("event_date")      // the occasion itself (for countdown)
  startsAt    DateTime? @map("starts_at")       // when banner starts showing
  endsAt      DateTime? @map("ends_at")         // when banner stops showing
  gradient    Json?                             // ["#3D0020","#2B0018"]
  bannerImage String?   @map("banner_image")    // optional background image URL
  // Occasion → Collection / Category mapping. When set, the "Shop Now"
  // CTA on the banner deep-links into a pre-filtered shop view scoped to
  // these collections / categories. JSONB string-arrays so admins can pick
  // multiple destinations per occasion (e.g. Mother's Day → ["jewellery",
  // "personalised-mugs"]) without touching products themselves.
  collectionSlugs Json?  @map("collection_slugs") // ["mothers-day-edit", ...]
  categoryNames   Json?  @map("category_names")   // ["Jewellery", "Mugs", ...]
  active      Boolean   @default(true)
  order       Int       @default(0)             // manual sort weight
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([active, placement, order])
  @@map("announcements")
}

// Curated customer testimonials — shown on the home page of web + mobile.
// Super-admin creates these manually (not self-service like Reviews) so the
// copy stays editorial. Optional productId links the testimonial to a
// specific product so the card can show a "they loved this product" footer.
model Testimonial {
  id           String   @id @default(uuid()) @db.Uuid
  name         String                                // display name (already short-formed by admin)
  avatar       String?                               // optional portrait URL
  location     String?                               // "Mumbai", "Bengaluru, India"
  rating       Int      @default(5)                  // 1–5
  text         String                                // the quote itself
  verified     Boolean  @default(false)              // admin toggle → shows gold check in mobile
  featured     Boolean  @default(false)              // pinned to the top of the carousel
  status       String   @default("pending")          // "pending" | "approved" | "rejected"

  // Optional product linkage — clicking the testimonial footer on mobile
  // routes to this product page.
  productId    String?  @db.Uuid @map("product_id")
  productTitle String?  @map("product_title")        // cached at save-time for perf
  productImage String?  @map("product_image")        // cached thumbnail URL
  productSlug  String?  @map("product_slug")         // cached slug for deep-link

  order        Int      @default(0)                  // manual sort weight (higher = first)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([status, featured, order])
  @@map("testimonials")
}

// ─────────────────────────────────────────────────────────────────────────
// Returns / RMA flow (Phase C-1 of order page)
// ─────────────────────────────────────────────────────────────────────────
//
// Customer can request a return on any delivered order item within the
// return window (default 7 days post-delivery, configurable per product
// via metadata.returnWindowDays).
//
// State machine:
//   pending   — customer has filed request, awaiting admin review
//   approved  — admin OK'd; customer must ship the item back (or admin
//               will arrange pickup); shows return-shipping instructions
//   rejected  — admin declined (out of window, hygiene category, etc.)
//   received  — admin marked the returned parcel as physically received
//   refunded  — admin processed a refund linked back to the request;
//               this is a terminal state. Refund itself is recorded in
//               order.metadata.refunds[] (existing structure)
//   cancelled — customer (or admin) cancelled the request before approval
//
// One ReturnRequest per OrderItem is the typical case; a customer can
// also file a "whole order" return (orderItemId nullable) when every
// item is going back together.
enum ReturnStatus {
  pending
  approved
  rejected
  received
  refunded
  cancelled
}

model ReturnRequest {
  id              String       @id @default(uuid()) @db.Uuid
  orderId         String       @db.Uuid                                // parent order
  orderItemId     String?      @db.Uuid                                // null → whole order
  customerId      String       @db.Uuid                                // who filed it (always the order's customer)
  qty             Int          @default(1)                             // partial-qty returns
  reason          String                                               // dropdown enum on UI side ("defective", "wrong_item", "changed_mind", "other")
  details         String?                                              // free-text from customer
  photos          String[]                                             // /api/files URLs of customer-uploaded proof
  status          ReturnStatus @default(pending)

  // Admin decision
  approvedAt      DateTime?
  approvedById    String?      @db.Uuid                                // CompanyUser.id
  rejectedAt      DateTime?
  rejectReason    String?

  // Logistics
  pickupAddress   Json?                                                // sometimes different from shipping address
  carrier         String?                                              // return-courier name
  trackingNumber  String?                                              // return AWB
  receivedAt      DateTime?                                            // when the parcel was scanned in by warehouse

  // Refund link — when admin processes a refund triggered by this RMA,
  // we copy the refund-entry reference (timestamp + razorpay_refund_id)
  // here for fast cross-reference. The full refund record stays in
  // order.metadata.refunds[] which is the source of truth.
  refundedAt      DateTime?
  refundEntry     Json?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer        Customer     @relation(fields: [customerId], references: [id])
  // orderItem is optional — `null` represents a whole-order RMA. ON DELETE
  // SET NULL because we never want to lose a customer's return-request
  // audit trail just because admin later edited the line away. The
  // app-level guard in OrdersService.editOrder refuses to remove a
  // line with active RMAs, so the NULL fallback only fires for
  // out-of-band deletions.
  orderItem       OrderItem?   @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([customerId, status])
  @@index([status, createdAt])
  @@index([orderItemId])
  @@map("return_requests")
}

// ─────────────────────────────────────────────────────────────────────────
// DPDP Act compliance — consent records, data exports, deletion requests
// ─────────────────────────────────────────────────────────────────────────
//
// India's Digital Personal Data Protection Act (2023) requires:
//   - Granular, withdrawable consent per processing purpose
//   - Right to access (data export in machine-readable form)
//   - Right to correction (already supported via account edit)
//   - Right to erasure (account deletion, with legitimate-interest carve-outs
//     for tax/accounting records that must be kept ~7 years)
//   - Audit trail of every consent change
//
// These models implement that. Cron `processScheduledDeletions` runs daily
// and anonymizes PII for any customer whose `dataDeletionScheduledFor` is
// in the past — we keep order history (tax compliance) but redact name,
// email, phone, addresses, customizer photos.

enum ConsentCategory {
  essential       // login, cart, checkout — cannot be withdrawn (DPDP "necessary")
  analytics       // GA4 + Sentry + page views
  marketing       // Meta Pixel + GTM + abandoned-cart nudges + push promos
  ai_personalization // AI intent classification + recommendation
}

enum DataExportStatus {
  pending
  ready
  expired
  cancelled
}

model ConsentRecord {
  id          String          @id @default(uuid()) @db.Uuid
  customerId  String          @db.Uuid
  category    ConsentCategory
  granted     Boolean
  // Free-form policy version reference so we can require re-consent when
  // we materially change how data is processed (e.g. add a new analytics
  // vendor). Bump this in code; consents are silent-migrated by default.
  policyVersion String        @default("1.0")
  // Where the consent decision was recorded — useful for audits.
  source      String?         // "signup" | "settings_page" | "cookie_banner" | "admin_override"
  ipAddress   String?
  userAgent   String?

  recordedAt  DateTime        @default(now())

  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Most-recent-per-category lookup is the hot path. The index covers it.
  @@index([customerId, category, recordedAt])
  @@map("consent_records")
}

model DataExportRequest {
  id           String           @id @default(uuid()) @db.Uuid
  customerId   String           @db.Uuid
  status       DataExportStatus @default(pending)
  // The export payload itself is generated synchronously for the MVP
  // (most customers have <100 rows total) and stored inline. When we
  // outgrow this we swap to /api/files (signed URL) without changing
  // the request shape.
  payload      Json?
  sizeBytes    Int?
  createdAt    DateTime         @default(now())
  readyAt      DateTime?
  expiresAt    DateTime?        // ready exports auto-expire after 7 days

  customer     Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([status, expiresAt])
  @@map("data_export_requests")
}

// ============================================================
// Marketplace — Sellers / Vendors
// ============================================================

enum SellerType {
  individual
  business
}

enum SellerStatus {
  pending     // submitted onboarding, awaiting super-admin review
  approved    // verified — may list products
  rejected
  suspended
}

enum SellerMode {
  vendor_only  // provides manufacturing / printing to Gifteeng only
  full_seller  // also lists & sells their own products
}

model Seller {
  id                String       @id @default(uuid()) @db.Uuid

  // ── Login identity (phone-OTP) ──────────────────────────────
  phone             String       @unique
  email             String?

  // ── Business identity ──────────────────────────────────────
  type              SellerType
  mode              SellerMode   @default(full_seller)
  brandName         String       // shown to buyers on the marketplace
  legalName         String       // proprietor name OR registered company name

  // ── Tax / compliance ───────────────────────────────────────
  gstNumber         String?
  panNumber         String?

  // ── Contact person (proprietor / director) ─────────────────
  contactName       String
  contactPhone      String?
  contactEmail      String?

  // ── Location — pincode drives proximity-based seller scoring ─
  addressLine       String?
  city              String?
  state             String?
  pincode           String

  // ── Payout details (seller enters these themselves) ─────────
  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?

  // ── KYC documents — [{ type, url }] uploaded during onboarding
  kycDocs           Json?

  // ── Marketplace state ──────────────────────────────────────
  status            SellerStatus @default(pending)
  rejectedReason    String?
  chargesCourier    Boolean      @default(false)
  dispatchDays      Int          @default(2)
  ratingAvg         Float        @default(0)
  ratingCount       Int          @default(0)

  // ── Store page identity ────────────────────────────────────
  slug              String?      @unique
  followerCount     Int          @default(0)
  hasTrademark      Boolean?
  trademarkNumber   String?

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  approvedAt        DateTime?

  products          SellerProduct[]
  assignments       OrderItemAssignment[]
  payouts           SellerPayout[]
  followers         SellerFollower[]

  @@index([status])
  @@index([pincode])
  @@map("sellers")
}

// Single-use phone OTP for seller onboarding + login. The code is hashed
// at rest; the plaintext is only ever sent over SMS.
model SellerOtp {
  id         String    @id @default(uuid()) @db.Uuid
  phone      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone])
  @@map("seller_otps")
}

model SellerFollower {
  id         String   @id @default(uuid()) @db.Uuid
  sellerId   String   @db.Uuid
  customerId String   @db.Uuid
  createdAt  DateTime @default(now())

  seller     Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, customerId])
  @@index([customerId])
  @@map("seller_followers")
}

enum SellerProductStatus {
  pending    // seller listed it, awaiting super-admin verification
  approved   // verified — visible on the marketplace
  rejected
}

// A seller's offer to sell a product. Either the seller created the
// product themselves (isOwnListing = true) or they requested to also
// sell an existing catalogue product (isOwnListing = false). Every
// offer is verified by a super-admin before it goes live.
model SellerProduct {
  id             String              @id @default(uuid()) @db.Uuid
  sellerId       String              @db.Uuid
  productId      String              @db.Uuid

  isOwnListing   Boolean             @default(false)

  price          Decimal             @db.Decimal(12, 2)  // seller's selling price
  stock          Int                 @default(0)

  status         SellerProductStatus @default(pending)
  rejectedReason String?

  // Product rating specific to THIS seller's offer (separate from the
  // seller's overall rating, which lives on Seller.ratingAvg).
  ratingAvg      Float               @default(0)
  ratingCount    Int                 @default(0)
  viewCount      Int                 @default(0)

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  approvedAt     DateTime?

  seller         Seller              @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  product        Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems      CartItem[]
  orderItems     OrderItem[]
  assignments    OrderItemAssignment[]

  @@unique([sellerId, productId])
  @@index([status])
  @@index([productId, status])
  @@index([sellerId, status])
  @@map("seller_products")
}

// Each marketplace order item gets an assignment record tracking which seller
// is fulfilling it. When a seller misses their deadline the record flips to
// "floating" and a new assignment is created for the next-best seller.
// The chain of attempts for one item is queryable via orderItemId.
model OrderItemAssignment {
  id              String           @id @default(uuid()) @db.Uuid
  orderItemId     String           @db.Uuid
  sellerId        String           @db.Uuid
  sellerProductId String?          @db.Uuid

  status          AssignmentStatus @default(pending)
  attemptNumber   Int              @default(1)

  assignedAt          DateTime         @default(now())
  deadlineAt          DateTime
  acceptedAt          DateTime?
  scheduledDispatchAt DateTime?
  dispatchedAt        DateTime?
  deliveredAt         DateTime?
  returnedAt          DateTime?

  // Courier details — seller fills these in when dispatching
  useOwnCourier   Boolean          @default(false)
  courier         String?
  awb             String?
  trackingUrl     String?
  notes           String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  orderItem       OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  seller          Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sellerProduct   SellerProduct?   @relation(fields: [sellerProductId], references: [id], onDelete: SetNull)
  payoutItem      SellerPayoutItem?

  @@index([orderItemId])
  @@index([sellerId])
  @@index([status])
  @@index([deadlineAt])
  @@map("order_item_assignments")
}

// ── Payouts ───────────────────────────────────────────────────────────────────

// Admin-editable platform-wide settings stored as key-value JSON.
// Currently used for: marketplace_commission_rate (default 0.10 = 10%).
model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @default(now())

  @@map("platform_settings")
}

// One payout record per seller per batch. Created by the payout cron once all
// included items have passed the return window + 10-day hold.
model SellerPayout {
  id               String      @id @default(uuid()) @db.Uuid
  sellerId         String      @db.Uuid

  grossAmount      Decimal     @db.Decimal(12, 2)
  commissionRate   Decimal     @db.Decimal(5, 4)   // snapshot of the rate at payout time
  commissionAmount Decimal     @db.Decimal(12, 2)
  netAmount        Decimal     @db.Decimal(12, 2)

  status           PayoutStatus @default(eligible)
  paymentRef       String?      // bank transfer / UTR number
  notes            String?
  paidAt           DateTime?

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  seller  Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  items   SellerPayoutItem[]

  @@index([sellerId])
  @@index([status])
  @@map("seller_payouts")
}

// One line per fulfilled order item included in a payout batch.
model SellerPayoutItem {
  id           String   @id @default(uuid()) @db.Uuid
  payoutId     String   @db.Uuid
  assignmentId String   @db.Uuid @unique

  grossAmount  Decimal  @db.Decimal(12, 2)

  payout     SellerPayout        @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  assignment OrderItemAssignment @relation(fields: [assignmentId], references: [id])

  @@index([payoutId])
  @@map("seller_payout_items")
}
