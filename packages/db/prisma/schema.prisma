// Deploy 120 — Product Drop campaigns.
// Admin picks a real product, sets a shipping-only price, win odds and a
// daily/total limit. A customer who plays (once a day) has a chance to
// "win" the product; on win a voucher (RewardInstance type=free_product)
// is issued with value = <productId>:<shippingInr>. The cart applies the
// voucher by replacing the product's line-item price with shippingInr.
model ProductDropConfig {
  id            String    @id @default(uuid()) @db.Uuid
  productId     String    @map("product_id") @db.Uuid
  // Which mechanic the admin is running for this product. All modes
  // eventually award a `free_product` voucher that claims the product at
  // the `shippingInr` price.
  //   drop          — pure lottery: roll vs winOddsPct  (Deploy 120)
  //   guess_price   — guess base price within tolerance (Deploy 121)
  //   daily_deal    — scratch-to-unlock, guaranteed win (Deploy 121)
  //   product_wheel — spin; server picks winner slice   (Deploy 121)
  gameMode      String    @default("drop") @map("game_mode")
  // Mode-specific params — e.g. { tolerancePct: 10 } for guess_price,
  // { slices: [{productId, weight}, ...] } for product_wheel.
  modeConfig    Json?     @map("mode_config")
  // Price the winner pays (typically shipping-only — admin decides). In rupees.
  shippingInr   Int       @map("shipping_inr")
  // Win probability as a percentage 0–100 (fractional, e.g. 2.5).
  // Only used by "drop" mode; other modes define win conditions differently.
  winOddsPct    Decimal   @default(1.0) @map("win_odds_pct") @db.Decimal(5, 2)
  // Max plays a single customer can make per day (usually 1).
  dailyLimit    Int       @default(1)   @map("daily_limit")
  // Total winners cap across the whole campaign. Null = unlimited.
  maxWinners    Int?                     @map("max_winners")
  winnersCount  Int       @default(0)   @map("winners_count")
  // How long the winner has to checkout before the voucher auto-expires.
  claimWindowHours Int    @default(72)  @map("claim_window_hours")
  isActive      Boolean   @default(true) @map("is_active")
  startsAt      DateTime?               @map("starts_at")
  endsAt        DateTime?               @map("ends_at")
  // Optional override for the card UI; defaults fall back to product fields.
  title         String?
  subtitle      String?
  bannerImage   String?                 @map("banner_image")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt    @map("updated_at")

  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([isActive, startsAt, endsAt])
  @@index([gameMode, isActive])
  @@map("product_drop_configs")
}

model MarketplaceLink {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  iconUrl   String?  @map("icon_url")
  storeUrl  String   @map("store_url")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

