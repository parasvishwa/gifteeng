// Gifteeng unified schema — merges B2B and B2C into a single Postgres DB.
// Two auth silos (customers, company_users) share one commerce backbone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum Channel {
  b2c
  b2b
}

enum UserRole {
  super_admin
  sales_admin
  hr_admin
  production
  employee
}

enum CompanyStatus {
  active
  suspended
  pending
}

enum OrderStatus {
  new_order
  confirmed
  in_production
  ready_to_ship
  shipped
  delivered
  cancelled
  returned
}

enum OrderPriority {
  low
  normal
  high
  urgent
}

enum PaymentMethod {
  razorpay
  wallet
  cod
  invoice
}

enum PaymentStatus {
  pending
  authorized
  captured
  failed
  refunded
}

enum CampaignType {
  festival
  reward
  onboarding
  milestone
  custom
}

enum CampaignStatus {
  draft
  active
  completed
  cancelled
}

enum AllocationStatus {
  pending
  partial
  redeemed
  expired
}

enum WalletOwnerType {
  company
  employee
}

enum WalletTxnType {
  topup
  debit
  refund
  lock
  unlock
}

enum FileOwnerType {
  product
  customer
  company_user
  order
  review
  design_template
  thank_you_card
  system
}

// ============================================================
// Identity & tenancy
// ============================================================

model Company {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  slug           String        @unique
  logoUrl        String?
  brandColor     String?
  status         CompanyStatus @default(active)
  billingEmail   String?
  billingAddress Json?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  companyUsers   CompanyUser[]
  companyProducts CompanyProduct[]
  wallets        Wallet[]
  orders         Order[]
  campaigns      Campaign[]
  ownedProducts  Product[]     @relation("OwnerCompany")
  priceSlabs     PriceSlab[]

  @@map("companies")
}

model CompanyUser {
  id            String    @id @default(uuid()) @db.Uuid
  companyId     String    @db.Uuid
  email         String
  phone         String?
  fullName      String?
  passwordHash  String?
  role          UserRole
  invitedBy     String?   @db.Uuid
  invitedAt     DateTime?
  activatedAt   DateTime?
  lastLoginAt   DateTime?
  isActive      Boolean   @default(true)
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ordersPlaced  Order[]   @relation("OrderedByCompanyUser")
  allocations   CampaignAllocation[]
  walletsOwned  Wallet[]  @relation("EmployeeWallet")

  @@unique([companyId, email])
  @@index([companyId, role])
  @@map("company_users")
}

model Customer {
  id            String    @id @default(uuid()) @db.Uuid
  email         String?   @unique
  phone         String?   @unique
  fullName      String?
  passwordHash  String?
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  isAdmin       Boolean   @default(false)
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  cart          Cart?
  wishlists     Wishlist[]
  reviews       Review[]
  savedAddresses SavedAddress[]
  customerPhotos CustomerPhoto[]

  @@map("customers")
}

model PhoneOtp {
  id         String   @id @default(uuid()) @db.Uuid
  phone      String
  codeHash   String
  purpose    String // 'b2c_login' | 'b2c_profile' | etc.
  attempts   Int      @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([phone, purpose])
  @@map("phone_otps")
}

// ============================================================
// Catalog
// ============================================================

model Product {
  id               String   @id @default(uuid()) @db.Uuid
  slug             String   @unique
  title            String
  description      String?
  category         String?
  basePrice        Decimal  @db.Decimal(12, 2)
  currency         String   @default("INR")
  sku              String?
  inventory        Int      @default(0)
  isCustomizable   Boolean  @default(false)
  mockupTemplates  Json?    // canvas templates
  images           Json?    // array of {url, alt}
  b2cEnabled       Boolean  @default(true)
  b2bEnabled       Boolean  @default(false)
  ownerCompanyId   String?  @db.Uuid // null = global
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ownerCompany     Company? @relation("OwnerCompany", fields: [ownerCompanyId], references: [id])
  variantOptions   ProductVariantOption[]
  companyProducts  CompanyProduct[]
  priceSlabs       PriceSlab[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  wishlistItems    WishlistItem[]
  reviews          Review[]
  collectionLinks  ProductCollection[]
  catalogItems     CatalogItem[]

  @@index([category, b2cEnabled])
  @@index([ownerCompanyId])
  @@map("products")
}

model ProductVariantOption {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @db.Uuid
  name      String  // 'color', 'size', 'material'
  value     String
  priceDelta Decimal @default(0) @db.Decimal(12, 2)
  sku       String?
  inventory Int     @default(0)
  image     String?

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, name])
  @@map("product_variant_options")
}

model CompanyProduct {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @db.Uuid
  productId     String   @db.Uuid
  overridePrice Decimal? @db.Decimal(12, 2)
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, productId])
  @@map("company_products")
}

model PriceSlab {
  id         String  @id @default(uuid()) @db.Uuid
  productId  String  @db.Uuid
  companyId  String? @db.Uuid // null = global tier
  minQty     Int
  maxQty     Int?
  unitPrice  Decimal @db.Decimal(12, 2)

  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  company    Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([productId, companyId])
  @@map("price_slabs")
}

model Collection {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  title       String
  description String?
  heroImage   String?
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  products    ProductCollection[]

  @@map("collections")
}

model ProductCollection {
  productId    String @db.Uuid
  collectionId String @db.Uuid
  sortOrder    Int    @default(0)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@map("product_collections")
}

model Catalog {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  title       String
  description String?
  heroImage   String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  items       CatalogItem[]
  enquiries   CatalogEnquiry[]

  @@map("catalogs")
}

model CatalogItem {
  id         String  @id @default(uuid()) @db.Uuid
  catalogId  String  @db.Uuid
  productId  String  @db.Uuid
  sortOrder  Int     @default(0)

  catalog    Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([catalogId, productId])
  @@map("catalog_items")
}

model CatalogEnquiry {
  id            String   @id @default(uuid()) @db.Uuid
  catalogId     String?  @db.Uuid
  contactName   String
  contactEmail  String
  contactPhone  String?
  companyName   String?
  message       String?
  requestedItems Json?   // [{productId, qty, notes}]
  status        String   @default("new") // new | contacted | quoted | closed
  createdAt     DateTime @default(now())

  catalog       Catalog? @relation(fields: [catalogId], references: [id])

  @@map("catalog_enquiries")
}

// ============================================================
// Commerce (orders, cart, etc.)
// ============================================================

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  orderNumber     String        @unique
  channel         Channel
  status          OrderStatus   @default(new_order)
  priority        OrderPriority @default(normal)

  customerId      String?       @db.Uuid
  companyId       String?       @db.Uuid
  companyUserId   String?       @db.Uuid

  subtotal        Decimal       @db.Decimal(12, 2)
  discountTotal   Decimal       @default(0) @db.Decimal(12, 2)
  shippingTotal   Decimal       @default(0) @db.Decimal(12, 2)
  taxTotal        Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal       @db.Decimal(12, 2)
  currency        String        @default("INR")

  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(pending)
  razorpayOrderId String?
  razorpayPaymentId String?
  walletTxnId     String?       @db.Uuid
  campaignAllocationId String?  @db.Uuid

  shippingAddress Json?
  billingAddress  Json?
  discountCode    String?
  notes           String?
  metadata        Json?

  placedAt        DateTime      @default(now())
  confirmedAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  updatedAt       DateTime      @updatedAt

  customer        Customer?     @relation(fields: [customerId], references: [id])
  company         Company?      @relation(fields: [companyId], references: [id])
  companyUser     CompanyUser?  @relation("OrderedByCompanyUser", fields: [companyUserId], references: [id])
  items           OrderItem[]
  shipments       Shipment[]

  @@index([channel, status])
  @@index([customerId])
  @@index([companyId])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @db.Uuid
  productId      String   @db.Uuid
  qty            Int
  unitPrice      Decimal  @db.Decimal(12, 2)
  totalPrice     Decimal  @db.Decimal(12, 2)
  variantOptions Json?    // snapshot of chosen variants
  customization  Json?    // fabric.js canvas JSON + assets
  snapshot       Json?    // product snapshot at time of order

  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Shipment {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @db.Uuid
  provider        String   @default("shiprocket")
  awb             String?
  courier         String?
  trackingUrl     String?
  status          String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  providerPayload Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("shipments")
}

model Cart {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String?  @unique @db.Uuid
  sessionKey String?  @unique
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]

  @@map("carts")
}

model CartItem {
  id             String   @id @default(uuid()) @db.Uuid
  cartId         String   @db.Uuid
  productId      String   @db.Uuid
  qty            Int
  variantOptions Json?
  customization  Json?
  addedAt        DateTime @default(now())

  cart           Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id])

  @@index([cartId])
  @@map("cart_items")
}

model SavedAddress {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  label      String?
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String   @default("IN")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("saved_addresses")
}

model Wishlist {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  name       String   @default("Default")
  createdAt  DateTime @default(now())

  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      WishlistItem[]

  @@index([customerId])
  @@map("wishlists")
}

model WishlistItem {
  wishlistId String @db.Uuid
  productId  String @db.Uuid
  addedAt    DateTime @default(now())

  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([wishlistId, productId])
  @@map("wishlist_items")
}

model Discount {
  id           String    @id @default(uuid()) @db.Uuid
  code         String    @unique
  description  String?
  percent      Decimal?  @db.Decimal(5, 2)
  amount       Decimal?  @db.Decimal(12, 2)
  minOrderTotal Decimal? @db.Decimal(12, 2)
  usageLimit   Int?
  usedCount    Int       @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@map("discounts")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @db.Uuid
  customerId String?  @db.Uuid
  rating     Int
  title      String?
  body       String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id])
  photos     CustomerPhoto[]

  @@index([productId])
  @@map("reviews")
}

model CustomerPhoto {
  id         String   @id @default(uuid()) @db.Uuid
  reviewId   String?  @db.Uuid
  customerId String?  @db.Uuid
  url        String
  caption    String?
  createdAt  DateTime @default(now())

  review     Review?   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id])

  @@map("customer_photos")
}

// ============================================================
// B2B wallet / campaigns
// ============================================================

model Wallet {
  id            String           @id @default(uuid()) @db.Uuid
  ownerType     WalletOwnerType
  companyId     String?          @db.Uuid
  companyUserId String?          @db.Uuid
  balance       Decimal          @default(0) @db.Decimal(14, 2)
  lockedBalance Decimal          @default(0) @db.Decimal(14, 2)
  currency      String           @default("INR")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  company       Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyUser   CompanyUser?     @relation("EmployeeWallet", fields: [companyUserId], references: [id], onDelete: Cascade)
  transactions  WalletTransaction[]

  @@unique([ownerType, companyId, companyUserId])
  @@map("wallets")
}

model WalletTransaction {
  id        String        @id @default(uuid()) @db.Uuid
  walletId  String        @db.Uuid
  type      WalletTxnType
  amount    Decimal       @db.Decimal(14, 2)
  reference String?       // orderId, campaignId, razorpayPaymentId
  notes     String?
  createdAt DateTime      @default(now())

  wallet    Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model Campaign {
  id          String         @id @default(uuid()) @db.Uuid
  companyId   String         @db.Uuid
  type        CampaignType
  status      CampaignStatus @default(draft)
  title       String
  description String?
  budgetTotal Decimal        @db.Decimal(14, 2)
  perEmployeeAmount Decimal? @db.Decimal(12, 2)
  startsAt    DateTime?
  endsAt      DateTime?
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  allocations CampaignAllocation[]

  @@index([companyId, status])
  @@map("campaigns")
}

model CampaignAllocation {
  id             String           @id @default(uuid()) @db.Uuid
  campaignId     String           @db.Uuid
  companyUserId  String           @db.Uuid
  amount         Decimal          @db.Decimal(12, 2)
  redeemedAmount Decimal          @default(0) @db.Decimal(12, 2)
  status         AllocationStatus @default(pending)
  expiresAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  campaign       Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  companyUser    CompanyUser      @relation(fields: [companyUserId], references: [id], onDelete: Cascade)

  @@unique([campaignId, companyUserId])
  @@map("campaign_allocations")
}

// ============================================================
// Platform / misc
// ============================================================

model DesignTemplate {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  canvasJson Json
  previewUrl String?
  category   String?
  createdAt  DateTime @default(now())

  @@map("design_templates")
}

model ThankYouCard {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  canvasJson Json
  previewUrl String?
  createdAt  DateTime @default(now())

  @@map("thank_you_cards")
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model PageView {
  id        String   @id @default(uuid()) @db.Uuid
  path      String
  referrer  String?
  userAgent String?
  customerId String? @db.Uuid
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@map("page_views")
}

model FileAsset {
  id         String        @id @default(uuid()) @db.Uuid
  ownerType  FileOwnerType
  ownerId    String?       @db.Uuid
  path       String        // relative path under UPLOAD_DIR
  mimeType   String?
  sizeBytes  Int?
  checksum   String?
  createdAt  DateTime      @default(now())

  @@index([ownerType, ownerId])
  @@map("files")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  channel    String   // 'email' | 'sms' | 'inapp'
  recipient  String
  subject    String?
  body       String
  status     String   @default("queued")
  sentAt     DateTime?
  error      String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([status, createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorType  String   // 'customer' | 'company_user' | 'system'
  actorId    String?  @db.Uuid
  action     String
  entityType String?
  entityId   String?
  payload    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorType, actorId, createdAt])
  @@map("audit_log")
}
