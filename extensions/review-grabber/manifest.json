{
  "manifest_version": 3,
  "name": "Gifteeng Review Grabber",
  "description": "Scrape reviews from Amazon, Flipkart, Myntra & Google → import into Gifteeng review system in one click.",
  "version": "1.2.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gifteeng Review Grabber"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.amazon.in/*",
    "https://*.amazon.com/*",
    "https://*.flipkart.com/*",
    "https://*.myntra.com/*",
    "https://*.meesho.com/*",
    "https://*.google.com/*",
    "https://*.gifteeng.com/*",
    "https://new-api.gifteeng.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.amazon.in/*", "https://*.amazon.com/*"],
      "js": ["content-scripts/amazon.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.flipkart.com/*"],
      "js": ["content-scripts/flipkart.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.myntra.com/*"],
      "js": ["content-scripts/myntra.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.meesho.com/*"],
      "js": ["content-scripts/meesho.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.google.com/maps/*", "https://*.google.com/search*"],
      "js": ["content-scripts/google.js"],
      "run_at": "document_idle"
    }
  ]
}
