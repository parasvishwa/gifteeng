# ──────────────────────────────────────────────────────────────────────────
# Gifteeng — environment template
# ──────────────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit .env to git.
# Production source of truth is /srv/gifteeng/.env on the VPS.
# ──────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────
# Point at pgbouncer (port 6432) in production; ?pgbouncer=true tells
# Prisma to disable prepared statements (incompatible with transaction
# pooling). connection_limit is per-process; with 4 cluster workers we
# end up with 4×50 = 200 client conns, multiplexed onto ~25 real backends.
DATABASE_URL="postgresql://gifteeng:CHANGEME@127.0.0.1:6432/gifteeng?schema=public&pgbouncer=true&connection_limit=50"

# ── Redis (cache + realtime SSE pub/sub) ─────────────────────────────────
REDIS_URL="redis://127.0.0.1:6379"

# ── API ───────────────────────────────────────────────────────────────────
API_BASE_URL="https://new-api.gifteeng.com"
API_PORT="4000"
# Number of cluster worker processes. 0/1 = single process (dev). 4 in prod.
WEB_CONCURRENCY="4"

# ── Web (Next.js) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL="https://new-api.gifteeng.com"
NEXT_PUBLIC_B2C_HOST="new.gifteeng.com"
NEXT_PUBLIC_B2B_HOST="new-business.gifteeng.com"

# ── Auth secrets ──────────────────────────────────────────────────────────
# Generate with `openssl rand -hex 32` (each MUST be ≥ 32 chars in prod —
# the API refuses to start otherwise).
JWT_B2C_SECRET="CHANGEME-generate-with-openssl-rand-hex-32"
JWT_B2B_SECRET="CHANGEME-generate-with-openssl-rand-hex-32"
JWT_EXPIRES_IN="7d"

# Signing secret for /api/files/<token>/* signed URLs. Same generation rule.
FILES_SIGNING_SECRET="CHANGEME-generate-with-openssl-rand-hex-32"

# ── Razorpay ──────────────────────────────────────────────────────────────
# Live keys: rzp_live_…  /  Test keys: rzp_test_…
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXX"
RAZORPAY_KEY_SECRET="CHANGEME"
RAZORPAY_WEBHOOK_SECRET="CHANGEME"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXX"  # same as RAZORPAY_KEY_ID; exposed to browser

# ── MSG91 (transactional SMS — OTPs + order confirmations) ───────────────
# DLT-registered templates required for production. See TRAI guidelines.
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""
MSG91_TEMPLATE_ID=""
MSG91_OTP_TEMPLATE_ID=""

# ── SMTP (transactional email — set up in Phase D) ───────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM='"Gifteeng" <support@gifteeng.com>'

# ── GST validation API (fetch firm name + address from GSTIN) ────────────
GST_API_PROVIDER="masters_india"
GST_API_KEY=""

# ── Shipping (Shiprocket — auto AWB / label printing) ────────────────────
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""

# ── Upload directory (local file storage) ────────────────────────────────
UPLOAD_DIR="/var/gifteeng/uploads"

# ──────────────────────────────────────────────────────────────────────────
# Optional — fill in when you turn each integration on
# ──────────────────────────────────────────────────────────────────────────

# Sentry (error monitoring). See docs/SENTRY-SETUP.md
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ENV="production"
# SENTRY_TRACES_SAMPLE_RATE="0.1"
# SENTRY_PROFILES_SAMPLE_RATE="0.1"

# AI providers — used for product description generation, intent
# classification, image generation. Either is sufficient (AiService
# auto-routes between them).
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# Invoice PDF firm details (placeholders default in to dev values; set
# REAL values for legally-compliant invoices).
# INVOICE_FIRM_NAME="Gifteeng Solutions Pvt. Ltd."
# INVOICE_FIRM_ADDR1=""
# INVOICE_FIRM_ADDR2=""
# INVOICE_FIRM_CITY=""
# INVOICE_FIRM_GSTIN=""
# INVOICE_FIRM_PAN=""
# INVOICE_FIRM_CIN=""
# INVOICE_FIRM_EMAIL="support@gifteeng.com"
# INVOICE_FIRM_PHONE=""
# INVOICE_FIRM_WEBSITE="https://gifteeng.com"

# Set to "development" to relax the production startup-secret assertions.
# NODE_ENV="development"
