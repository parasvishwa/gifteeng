{
  "name": "gifteeng",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "build":     "turbo run build",
    "dev":       "turbo run dev --parallel",
    "dev:api":   "pnpm --filter @gifteeng/api dev",
    "dev:web":   "pnpm --filter @gifteeng/web dev",
    "dev:mobile":"cd apps/mobile && flutter run",
    "lint":      "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test":      "turbo run test",
    "db:generate": "pnpm --filter @gifteeng/db prisma generate",
    "db:migrate":  "pnpm --filter @gifteeng/db prisma migrate dev",
    "db:studio":   "pnpm --filter @gifteeng/db prisma studio",
    "db:seed":     "pnpm --filter @gifteeng/db seed",
    "deploy":         "bash scripts/deploy.sh",
    "deploy:changed": "bash scripts/deploy-changed.sh",
    "sync:env":       "bash scripts/sync-env.sh",
    "vps:logs":       "ssh root@217.216.59.87 'journalctl -u gifteeng-api -f'",
    "vps:health":     "curl -fsS https://new-api.gifteeng.com/api/health && echo ' ok'",
    "vps:psql":       "ssh -t root@217.216.59.87 'sudo -u postgres psql -d gifteeng'",
    "vps:redis":      "ssh -t root@217.216.59.87 redis-cli",
    "vps:k6":         "ssh root@217.216.59.87 'k6 run --env BASE=http://127.0.0.1:4000 /tmp/k6-quick.js'",
    "vps:backup":     "ssh root@217.216.59.87 '/etc/cron.daily/gifteeng-pg-backup && ls -la /backups/ | tail -3'"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  }
}
