# ─── Flutter / Android / iOS ──────────────────────────────────────────────
apps/mobile/build/
apps/mobile/.dart_tool/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/ios/Pods/
apps/mobile/ios/Flutter/Flutter.framework/
apps/mobile/ios/Flutter/Flutter.podspec
apps/mobile/.idea/

# ─── Secrets — NEVER COMMIT ───────────────────────────────────────────────
# Master env. Each developer gets their own copy out-of-band (1Password
# attachment, encrypted USB). The source-of-truth in production is
# /srv/gifteeng/.env on the VPS.
.env
.env.local
.env.*.local
.env.production
.env.staging
!.env.example

# Android signing — owns the Play-Store identity. Losing this = can never
# update the same app ID again. Back up to a password manager.
apps/mobile/android/key.properties
apps/mobile/android/upload-keystore.jks
apps/mobile/android/app/upload-keystore.jks
apps/mobile/android/app/google-services.json

# iOS certs / Firebase config
apps/mobile/ios/Runner/GoogleService-Info.plist
apps/mobile/ios/Runner.xcworkspace/xcuserdata/

# ─── Deploy artifacts ─────────────────────────────────────────────────────
patch*.tar.gz
*.tar.gz
deploy_out/

# ─── Logs ─────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

