# ─── Dependencies ─────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnp.*

# ─── Build output ─────────────────────────────────────────────────────────
.next/
out/
dist/
build/
*.tsbuildinfo
.turbo/
